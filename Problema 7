#include <iostream>
#include <vector>
#include <string>

std::string numeroALetras(int n) {
    if (n < 0 || n > 100) return "FUERA DE RANGO";
    if (n == 0) return "CERO";
    if (n == 100) return "CIEN";

    std::vector<std::string> unidades = {"", "UNO", "DOS", "TRES", "CUATRO", "CINCO", "SEIS", "SIETE", "OCHO", "NUEVE"};
    std::vector<std::string> especiales = {"DIEZ", "ONCE", "DOCE", "TRECE", "CATORCE", "QUINCE", "DIECISÉIS", "DIECISIETE", "DIECIOCHO", "DIECINUEVE"};
    std::vector<std::string> decenas = {"", "", "VEINTE", "TREINTA", "CUARENTA", "CINCUENTA", "SESENTA", "SETENTA", "OCHENTA", "NOVENTA"};

    if (n >= 10 && n <= 19) return especiales[n - 10];
    if (n == 20) return "VEINTE";
    if (n > 20 && n < 30) return "VEINTI" + unidades[n % 10];

    int d = n / 10;
    int u = n % 10;

    if (u == 0) return decenas[d];
    return decenas[d] + " Y " + unidades[u];
}

int main() {
    int num = 12;
    std::cout << num << " escrito es: " << numeroALetras(num) << std::endl;
    
    int num2 = 45;
    std::cout << num2 << " escrito es: " << numeroALetras(num2) << std::endl;
    return 0;
}
