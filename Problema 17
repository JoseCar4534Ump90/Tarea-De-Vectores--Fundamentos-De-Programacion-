#include <iostream>
#include <vector>

std::vector<int> generarFibonacci(int n) {
    std::vector<int> fib;
    if (n <= 0) return fib;
    if (n >= 1) fib.push_back(0);
    if (n >= 2) fib.push_back(1);
    for (int i = 2; i < n; ++i) {
        fib.push_back(fib[i - 1] + fib[i - 2]);
    }
    return fib;
}

int main() {
    int n = 8;
    std::vector<int> serie = generarFibonacci(n);

    std::cout << "Los primeros " << n << " terminos de Fibonacci son: ";
    for (int x : serie) {
        std::cout << x << " ";
    }
    std::cout << std::endl;
    return 0;
}
